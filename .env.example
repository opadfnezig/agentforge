# Database
DATABASE_URL=postgres://agentforge:secret@localhost:5432/agentforge

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Platform
PORT=3001
FRONTEND_URL=http://localhost:3000
DATA_DIR=/opt/agentforge/data

# Docker
DOCKER_SOCKET=/var/run/docker.sock
AGENT_IMAGE=agentforge/claude-agent:latest

# Plane (optional)
PLANE_API_URL=https://api.plane.so
PLANE_API_KEY=plane_...
PLANE_WORKSPACE=my-workspace

# code-server
CODE_SERVER_PORT_START=8900
CODE_SERVER_PASSWORD=your-password
