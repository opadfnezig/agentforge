# Required: stable identifier for this host. Used as the {host_id} in
# lifecycle event POSTs to the ntfr server.
NTFR_HOST_ID=host-eu-1

# Optional: override the public spawner port. Default 9898.
NTFR_PORT=9898

# ntfr server (backend) base URL. If unset, lifecycle events stay in the
# outbox and are dropped after retry exhaustion with a warning.
NTFR_SERVER_URL=https://ntfr.example.com/api

# log level: debug | info | warn | error
NTFR_LOG_LEVEL=info

# Host directory the spawner mounts as /ntfr inside the container. This is
# the source of truth for primitive folders + compose.yml.
NTFR_HOST_WORKDIR=/home/ntfr/ntfr

# GID of the docker group ON THE HOST. Inside the container the spawner
# runs as a non-root `ntfr` user; this GID is added to its supplementary
# groups so it can talk to /var/run/docker.sock.
#   getent group docker | cut -d: -f3
NTFR_DOCKER_GID=998

# Tunables (defaults shown).
NTFR_LIFECYCLE_RETRY_MAX=5
NTFR_LIFECYCLE_RETRY_BACKOFF_MS=1000
NTFR_ORPHAN_RETRY_MAX=3
NTFR_ORPHAN_RETRY_BACKOFF_MS=10000
